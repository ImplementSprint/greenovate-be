{
  "serviceId": "greenovate",
  "name": "Greenovate Backend",
  "serviceType": "tribe",
  "baseUrl": "http://localhost:3001",
  "requiredScopes": ["tribe:greenovate:read", "tribe:greenovate:write"],
  "exposes": ["/api/v1/health", "/api/v1/location/resolve"],
  "consumes": ["payment", "email"],
  "healthCheck": "/api/v1/health",
  "version": "1.0.0",
  "description": "Greenovate Backend service built as a NestJS monorepo microservices backend"
}
