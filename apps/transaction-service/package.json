{
    "name":  "transaction-service",
    "version":  "0.0.1",
    "description":  "",
    "author":  "",
    "private":  true,
    "license":  "UNLICENSED",
    "scripts":  {
                    "build:POS-transaction":  "nest build",
                    "format:POS-transaction":  "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
                    "start:POS-transaction":  "nest start",
                    "start:dev:POS-transaction":  "nest start --watch",
                    "start:debug:POS-transaction":  "nest start --debug --watch",
                    "start:prod:POS-transaction":  "node dist/main",
                    "lint:POS-transaction":  "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
                    "test:POS-transaction":  "jest",
                    "test:watch:POS-transaction":  "jest --watch",
                    "test:cov:POS-transaction":  "jest --coverage",
                    "test:debug:POS-transaction":  "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
                    "test:pact:verify:POS-transaction":  "cross-env PACT_TEST_MODE=true PACT_BROKER_BASE_URL=http://localhost:9292 jest --config test/jest-pact.json --runInBand",
                    "test:e2e:POS-transaction":  "jest --config ./test/jest-e2e.json",
                    "build":  "nest build",
                    "start:prod":  "node dist/main"
                },
    "dependencies":  {
                         "@nestjs/common":  "^11.0.1",
                         "@nestjs/config":  "^4.0.4",
                         "@nestjs/core":  "^11.0.1",
                         "@nestjs/platform-express":  "^11.0.1",
                         "@supabase/supabase-js":  "^2.100.1",
                         "amqplib":  "^1.0.3",
                         "helmet":  "^8.1.0",
                         "reflect-metadata":  "^0.2.2",
                         "rxjs":  "^7.8.1",
                         "zod":  "^4.3.6",
                         "@implementsprint/sdk":  "^1.1.2"
                     },
    "devDependencies":  {
                            "@eslint/eslintrc":  "^3.2.0",
                            "@eslint/js":  "^9.18.0",
                            "@nestjs/cli":  "^11.0.0",
                            "@nestjs/schematics":  "^11.0.0",
                            "@nestjs/testing":  "^11.0.1",
                            "@pact-foundation/pact":  "^16.3.0",
                            "@types/amqplib":  "^0.10.8",
                            "@types/express":  "^5.0.0",
                            "@types/jest":  "^30.0.0",
                            "@types/node":  "^24.0.0",
                            "@types/supertest":  "^7.0.0",
                            "cross-env":  "^10.1.0",
                            "eslint":  "^9.18.0",
                            "eslint-config-prettier":  "^10.0.1",
                            "eslint-plugin-prettier":  "^5.2.2",
                            "globals":  "^17.0.0",
                            "jest":  "^29.7.0",
                            "prettier":  "^3.4.2",
                            "source-map-support":  "^0.5.21",
                            "supertest":  "^7.0.0",
                            "ts-jest":  "^29.2.0",
                            "ts-loader":  "^9.5.2",
                            "ts-node":  "^10.9.2",
                            "tsconfig-paths":  "^4.2.0",
                            "typescript":  "^5.7.3",
                            "typescript-eslint":  "^8.20.0"
                        },
    "jest":  {
                 "moduleFileExtensions":  [
                                              "js",
                                              "json",
                                              "ts"
                                          ],
                 "rootDir":  "src",
                 "testRegex":  ".*\\.spec\\.ts$",
                 "transform":  {
                                   "^.+\\.(t|j)s$":  "ts-jest"
                               },
                 "collectCoverageFrom":  [
                                             "**/*.(t|j)s"
                                         ],
                 "coverageDirectory":  "../coverage",
                 "testEnvironment":  "node",
                 "coverageThreshold":  {
                                           "global":  {
                                                          "branches":  70,
                                                          "functions":  70,
                                                          "lines":  70,
                                                          "statements":  70
                                                      }
                                       }
             }
}
