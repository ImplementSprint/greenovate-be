    {
      "title": "❌ Error Rate (%)",
      "type": "stat",
      "datasource": "InfluxDB-k6",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 16 },
      "targets": [
        {
          "query": "SELECT last(\"value\") * 100 FROM \"error_rate\" WHERE $timeFilter",
          "rawQuery": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "📊 HTTP Request Duration (All Endpoints)",
