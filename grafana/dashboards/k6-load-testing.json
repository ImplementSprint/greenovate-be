        {
          "query": "SELECT last(\"value\") AS \"p95_ms\" FROM \"stock_check_duration\" WHERE $timeFilter",
          "rawQuery": true,
          "refId": "B"
        },
        {
          "query": "SELECT last(\"value\") AS \"p95_ms\" FROM \"receipt_duration\" WHERE $timeFilter",
          "rawQuery": true,
          "refId": "C"
        }
