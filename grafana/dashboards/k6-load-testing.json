          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 150 }
            ]
          }
        }
      }
    },
    {
      "title": "🧾 Receipt Fetch Response Time (p95)",
      "type": "timeseries",
      "datasource": "InfluxDB-k6",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "query": "SELECT percentile(\"value\", 95) FROM \"receipt_duration\" WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "rawQuery": true,
