      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#FF6347", "mode": "fixed" },
          "custom": { "fillOpacity": 15, "lineWidth": 2, "thresholdsStyle": { "mode": "line" } },
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 500 }
            ]
          }
        }
      }
    },
    {
      "title": "⚡ Stock Check Response Time (p95)",
      "type": "timeseries",
