      "title": "🏷️ Thresholds Summary",
      "type": "table",
      "datasource": "InfluxDB-k6",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 22 },
      "targets": [
        {
          "query": "SELECT last(\"value\") AS \"p95_ms\" FROM \"transaction_duration\" WHERE $timeFilter",
          "rawQuery": true,
          "refId": "A"
